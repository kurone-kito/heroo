{
  "name": "@kurone-kito/pwt-web-solid",
  "version": "0.1.0",
  "private": true,
  "description": "The SolidJS web app boilerplate",
  "keywords": ["web", "solid.js", "boilerplate", "template"],
  "homepage": "https://github.com/kurone-kito/pnpm-workspace-template#readme",
  "bugs": "https://github.com/kurone-kito/pnpm-workspace-template/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurone-kito/pnpm-workspace-template.git",
    "directory": "packages/web-solid"
  },
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [".output", ".vinxi"],
  "scripts": {
    "build": "vinxi build",
    "clean": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" .output .vinxi coverage LICENSE node_modules/.cache",
    "dev": "vinxi dev",
    "prebuild": "cpy --flat ../../LICENSE .",
    "prepack": "pnpm run clean && pnpm run build",
    "prepare": "pnpm exec playwright install",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@kurone-kito/pwt-lib": "workspace:^",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.1.5",
    "solid-js": "^1.9.7"
  },
  "devDependencies": {
    "@kurone-kito/typescript-config": "^0.20.0-alpha.7",
    "@kurone-kito/vrc-icons-tw": "^0.14.0",
    "@playwright/test": "^1.53.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^24.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "cpy-cli": "^5.0.0",
    "daisyui": "^5.0.43",
    "jsdom": "^26.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-safe-area": "^0.6.0",
    "type-fest": "^4.41.0",
    "typescript": "~5.8.3",
    "vinxi": "^0.5.7",
    "vite-plugin-solid": "^2.11.7",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^20.11 || ^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
